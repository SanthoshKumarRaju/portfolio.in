#!/bin/bash

HOSTNAME=$(hostname)
IP=$(hostname -I | awk '{print $1}')
CPU=$(nproc)
MEM=$(free -h | awk '/Mem:/ {print $2}')
DISK=$(df -h / | awk 'NR==2 {print $5}')
UPTIME=$(uptime -p)

clear

figlet "DEV SERVER" | lolcat

printf "\n"

printf "Hostname     : %s\n" "$HOSTNAME" | lolcat
printf "IP Address   : %s\n" "$IP" | lolcat
printf "CPU Cores    : %s\n" "$CPU" | lolcat
printf "Memory       : %s\n" "$MEM" | lolcat
printf "Disk Usage   : %s\n" "$DISK" | lolcat
printf "Uptime       : %s\n" "$UPTIME" | lolcat

printf "\n"

echo "System Information" | lolcat
echo "-------------------" | lolcat

neofetch --stdout | lolcat

printf "\n"
echo "⚠ Unauthorized access is prohibited" | lolcat
printf "\n"